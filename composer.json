{
    "name": "niktomo/kura",
    "description": "A QueryBuilder-compatible APCu cache layer for Laravel reference data.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-apcu": "*",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "symfony/yaml": "^6.0|^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Kura\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kura\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kura\\KuraServiceProvider"
            ],
            "aliases": {
                "Kura": "Kura\\Facades\\Kura"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "pint",
        "check": [
            "@test",
            "@analyse"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
